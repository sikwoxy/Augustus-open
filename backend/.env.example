# Augustus Backend Environment
#
# Copy this file to .env and fill in your own values.
# Do not commit .env.

# Required: LLM API key.
LLM_API_KEY=

# Optional: custom API endpoint.
# Examples:
# - DeepSeek: https://api.deepseek.com
# - OpenAI-compatible gateways usually end with /v1
# - Leave empty for provider defaults.
LLM_BASE_URL=

# Required: main model.
# Examples:
# - claude-sonnet-4-6
# - deepseek-v4-flash
# - gpt-5
LLM_MODEL=

# Optional: force provider selection.
# Supported values:
# - anthropic
# - openai
LLM_PROVIDER=

# Optional: model used for task metadata generation.
LLM_META_MODEL=

# Optional: agent-specific overrides.
AUGUSTUS_MAIN_PROVIDER=
AUGUSTUS_MAIN_MODEL=
AUGUSTUS_MAIN_API_KEY=
AUGUSTUS_MAIN_BASE_URL=

AUGUSTUS_CODER_PROVIDER=
AUGUSTUS_CODER_MODEL=
AUGUSTUS_CODER_API_KEY=
AUGUSTUS_CODER_BASE_URL=

AUGUSTUS_RESEARCHER_PROVIDER=
AUGUSTUS_RESEARCHER_MODEL=
AUGUSTUS_RESEARCHER_API_KEY=
AUGUSTUS_RESEARCHER_BASE_URL=

AUGUSTUS_WRITER_PROVIDER=
AUGUSTUS_WRITER_MODEL=
AUGUSTUS_WRITER_API_KEY=
AUGUSTUS_WRITER_BASE_URL=

# Server.
AUGUSTUS_SERVER_PORT=3001
AUGUSTUS_SERVER_HOST=127.0.0.1
AUGUSTUS_BODY_LIMIT=10485760
AUGUSTUS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
AUGUSTUS_AUTH_TOKEN=

# Runtime data.
AUGUSTUS_DATA_DIR=.augustus
AUGUSTUS_TIME_ZONE=Asia/Shanghai

# Session and memory.
AUGUSTUS_SESSION_CONTEXT_MESSAGES=60
AUGUSTUS_MEMORY_MAX_ATOMS=12
AUGUSTUS_MEMORY_PROMPT_CHARS=4000

# Debug.
AUGUSTUS_DEBUG_MODE=false
